    "faqs": [
      {
        "id": "faq_1",
        "question": "Do price change often?",
        "answer": "We provide a wide range of services including residential, commercial, deep cleaning, carpet and window cleaning, and eco-friendly options tailored to your needs."
      },
      {
        "id": "faq_2",
        "question": "What payment method do you accept?",
        "answer": "We accept cash, EFT, and selected card and digital wallet payments."
      },
      {
        "id": "faq_3",
        "question": "How do deliveries work?",
        "answer": "We deliver within selected areas of Cape Town. Delivery schedules and fees are calculated at checkout based on your location."
      },
      {
        "id": "faq_4",
        "question": "Can I return products?",
        "answer": "Yes. Items may be returned within 7 days of purchase if unopened and in their original condition. Please keep your receipt."
      },
      {
        "id": "faq_5",
        "question": "What are your working hours?",
        "answer": "We are open Monday to Saturday, 9:00 AM to 7:00 PM, and Sundays from 9:00 AM to 3:00 PM."
      },
      {
        "id": "faq_6",
        "question": "How do we get our orders?",
        "answer": "We offer local delivery in Cape Town and surrounding areas, plus nationwide shipping through reliable couriers. Frozen goods and bulk items may require special handling - delivery fees depend on distance and order size. For detailed delivery options or bulk quotes, contact us at info@kathieskitchen.com or WhatsApp +27 71 575 1616."
      }
    ]
  },
